#version 430 core
layout(local_size_x = 64) in;

layout(std430, binding = [[VOLUMETRIC_LIGHT_ACCUMULATION_BINDING]]) buffer AccumulationBuffer {
    uint accumulation[];
};

uniform int u_total_elements;

void main() {
    uint gid = gl_GlobalInvocationID.x;
    if (gid >= u_total_elements) return;
    accumulation[gid] = 0;
}
