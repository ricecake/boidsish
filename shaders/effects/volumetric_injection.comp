#version 460 core

layout(local_size_x = 8, local_size_y = 8, local_size_z = 4) in;

// Shared memory for neighborhood statistics (8x8x4 workgroup)
shared vec4 s_current[8 * 8 * 4];

layout(rgba16f, binding = [[VOLUMETRIC_INJECTION_IMAGE_BINDING]]) uniform image3D outInjection;
layout(rgba16f, binding = [[VOLUMETRIC_HISTORY_IMAGE_BINDING]]) uniform image3D outHistory;

layout(binding = [[VOLUMETRIC_HISTORY_BINDING]]) uniform sampler3D uHistoryTexture;
layout(binding = 10) uniform sampler2D uBlueNoise;
// layout(binding = 11) uniform sampler3D u_curlTexture;

uniform mat4 uInvView;
uniform mat4 uInvProj;
uniform mat4 uPrevVP;
uniform vec3 uPrevCamPos;
uniform vec3 uPrevCamFront;

uniform float uAnisotropy;
uniform float uIntensity;
uniform float uTemporalAlpha;

#include "../helpers/math.glsl"
#include "../atmosphere/common.glsl"
#include "../helpers/lighting.glsl"
#include "../types/temporal_data.glsl"

#define COMPUTE_SHADER
#include "../particle_types.glsl"
#include "../helpers/spatial_hash.glsl"

uniform float u_cell_size;
uniform uint  u_grid_size;
uniform ivec3 u_grid_res;

#include "helpers/wind.glsl"

#include "lygia/generative/curl.glsl"

const int NUM_CASCADES = 4;
const float CASCADE_DISTANCES[4] = { 20.0, 60.0, 200.0, 1000.0 };

vec3 worldFromFroxel(ivec3 vox, vec3 jitter) {
    int cascade = vox.z / u_grid_res.z;
    int z_in_cascade = vox.z % u_grid_res.z;

    vec3 ndc;
    ndc.xy = (vec2(vox.xy) + jitter.xy) / vec2(u_grid_res.xy) * 2.0 - 1.0;

    float z_near = (cascade == 0) ? 0.1 : CASCADE_DISTANCES[cascade - 1];
    float z_far = CASCADE_DISTANCES[cascade];

    // Logarithmic distribution for planar Depth (Z)
    float linear_z = z_near * pow(z_far / z_near, (float(z_in_cascade) + jitter.z) / float(u_grid_res.z));

    // Reconstruct View Space Position using planar depth
    vec4 clipPos = vec4(ndc.xy, 0.0, 1.0);
    vec4 viewDir = uInvProj * clipPos;
    viewDir /= (abs(viewDir.w) > 0.0001) ? viewDir.w : 1.0;

    // Planar depth reconstruction: P.z = -linear_z (assuming OpenGL RH)
    // viewDir.z is typically -1 in view space before projection for a point on near plane
    // P = viewDir * (linear_z / -viewDir.z)
    float obliquity = length(viewDir.xyz) / max(0.0001, -viewDir.z);
    vec3 froxelViewPos = viewDir.xyz * (linear_z / max(0.0001, -viewDir.z));

    return (uInvView * vec4(froxelViewPos, 1.0)).xyz;
}

float getObliquity(ivec2 voxXY, vec3 jitter) {
    vec3 ndc;
    ndc.xy = (vec2(voxXY) + jitter.xy) / vec2(u_grid_res.xy) * 2.0 - 1.0;
    vec4 clipPos = vec4(ndc.xy, 0.0, 1.0);
    vec4 viewDir = uInvProj * clipPos;
    viewDir /= (abs(viewDir.w) > 0.0001) ? viewDir.w : 1.0;
    return length(viewDir.xyz) / max(0.0001, -viewDir.z);
}

void main() {
    ivec3 vox = ivec3(gl_GlobalInvocationID.xyz);
    bool out_of_bounds = (vox.x >= u_grid_res.x || vox.y >= u_grid_res.y || vox.z >= u_grid_res.z * NUM_CASCADES);

    // 1. Calculate current local scattering and extinction
    vec4 current_local = vec4(0.0);
    vec3 blueNoise = vec3(0.0);
    vec3 worldPos = vec3(0.0);

    if (!out_of_bounds) {
        // Animate jitter coordinates using frameIndex to prevent persistent sampling bias
        ivec2 noiseCoords = vox.xy + ivec2(vox.z * 13, vox.z * 17);
        noiseCoords += ivec2(frameIndex * 7, frameIndex * 13);

        blueNoise = fract(texelFetch(uBlueNoise, noiseCoords / textureSize(uBlueNoise, 0), 0).rgb   * 0.61803398875);

        // Use jitter in [0, 1] range which is centered on froxel centers (vox + 0.5)
        worldPos = worldFromFroxel(vox, blueNoise);

    // Calculate scattering and extinction
    Sampling s = getAtmospherePropertiesAtPos(worldPos);

    vec3 radiance = vec3(0.0);
    vec3 V = normalize(viewPos - worldPos);

