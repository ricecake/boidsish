        }
    }

*/

        radiance *= uIntensity * 3.0; // Boosted intensity for prominence

        // Convert atmospheric coefficients from per-KM to per-meter
        float obliquity = getObliquity(vox.xy, blueNoise);
        vec3 mieCoeff = s.mie * 0.001 * obliquity;
        float extinctionCoeff = (s.rayleigh.r + s.rayleigh.g + s.rayleigh.b + s.mie.r + s.mie.g + s.mie.b) / 3.0 * 0.001 * obliquity;

        current_local = vec4(radiance * mieCoeff, extinctionCoeff);
    }

    // 2. Populate shared memory for neighborhood clamping
    ivec3 l_id = ivec3(gl_LocalInvocationID.xyz);
    int flat_id = int(l_id.z * 64 + l_id.y * 8 + l_id.x);
    s_current[flat_id] = current_local;

    barrier();

    if (out_of_bounds) return;

    vec4 current = current_local;

    // Temporal accumulation
    if (uTemporalAlpha > 0.0) {
        vec4 prevClip = uPrevVP * vec4(worldPos, 1.0);
        vec3 prevNDC = prevClip.xyz / (abs(prevClip.w) > 0.0001 ? prevClip.w : 1.0);

        if (all(greaterThanEqual(prevNDC, vec3(-1.0))) && all(lessThanEqual(prevNDC, vec3(1.0)))) {
            // Reproject current world position into previous frame's froxel grid
            vec3 prevUV = prevNDC * 0.5 + 0.5;

            // Compensation for stochastic jitter to find the correct logical voxel
            prevUV.xy -= (blueNoise.xy - 0.5) / vec2(u_grid_res.xy);

            // Find previous cascade using planar depth (Z)
            float prevLinearZ = dot(worldPos - uPrevCamPos, uPrevCamFront);

            int prevCascade = -1;
            float z_near = 0.1;
            float z_far = 0.0;
            for (int i = 0; i < NUM_CASCADES; ++i) {
                if (prevLinearZ <= CASCADE_DISTANCES[i]) {
                    prevCascade = i;
                    z_far = CASCADE_DISTANCES[i];
                    if (i > 0) z_near = CASCADE_DISTANCES[i-1];
                    break;
                }
            }

            if (prevCascade != -1 && prevLinearZ > z_near) {
                float slice = clamp(log(prevLinearZ / z_near) / log(z_far / z_near), 0.0, 1.0);

                // Compensation for stochastic jitter in depth
                slice -= (blueNoise.z - 0.5) / float(u_grid_res.z);
                slice = clamp(slice, 0.0, 1.0);

                // Correct mapping from cascade/slice to [0,1] 3D texture coordinate
                // Use consistent continuous mapping to align with storage and composite shader
                float total_slices = float(u_grid_res.z * NUM_CASCADES);
                float w = (float(prevCascade * u_grid_res.z) + (slice * float(u_grid_res.z - 1) + 0.5)) / total_slices;

                vec4 history = texture(uHistoryTexture, vec3(prevUV.xy, w));
                if (all(greaterThanEqual(history, vec4(0.0))) && all(lessThanEqual(history, vec4(1000.0)))) {
                    // --- Neighborhood Clamping ---
                    vec4 m1 = vec4(0.0);
                    vec4 m2 = vec4(0.0);
                    int count = 0;

                    for (int z = -1; z <= 1; ++z) {
                        for (int y = -1; y <= 1; ++y) {
                            for (int x = -1; x <= 1; ++x) {
                                ivec3 neighbor_l_id = l_id + ivec3(x, y, z);
                                if (all(greaterThanEqual(neighbor_l_id, ivec3(0))) && all(lessThan(neighbor_l_id, ivec3(8, 8, 4)))) {
                                    vec4 val = s_current[neighbor_l_id.z * 64 + neighbor_l_id.y * 8 + neighbor_l_id.x];
                                    m1 += val;
                                    m2 += val * val;
                                    count++;
                                }
                            }
                        }
                    }

                    vec4 mean = m1 / float(count);
                    vec4 stddev = sqrt(max(vec4(0.0), (m2 / float(count)) - (mean * mean)));

                    // Clamp history to current neighborhood
                    float gamma = 1.2; // Tighter clamping for volume to reduce ghosting
                    vec4 minColor = mean - gamma * stddev;
                    vec4 maxColor = mean + gamma * stddev;
                    history = clamp(history, minColor, maxColor);

                    // --- Adaptive Temporal Alpha ---
                    float activeAlpha = uTemporalAlpha;

                    // 1. Luminance-based adaptation
                    float currentLum = dot(current.rgb, vec3(0.2126, 0.7152, 0.0722));
                    float historyLum = dot(history.rgb, vec3(0.2126, 0.7152, 0.0722));
                    float lumDiff = abs(currentLum - historyLum) / (max(currentLum, historyLum) + 0.01);

                    // Reduce alpha if there's a significant change in local luminance
                    activeAlpha *= 1.0 - smoothstep(0.1, 0.5, lumDiff);

                    // 2. Lightning pulse adaptation
                    // If a flash is happening, we want to react almost instantly
                    activeAlpha *= 1.0 - clamp(lightningPulse * 2.0, 0.0, 1.0);

                    // 3. Stability check (high variance = low alpha)
                    float spatialStd = dot(stddev.rgb, vec3(0.2126, 0.7152, 0.0722));
                    activeAlpha *= clamp(1.0 - (spatialStd / (currentLum + 0.001)), 0.0, 1.0);

                    current = mix(current, history, clamp(activeAlpha, 0.0, 0.99));
                }
            }
        }
    }

    // Safety clamp to prevent NaN/Inf propagation
    current = clamp(current, vec4(0.0), vec4(1000.0));
    if (any(isnan(current))) current = vec4(0.0);

    imageStore(outInjection, vox, current);
    imageStore(outHistory, vox, current);
}
