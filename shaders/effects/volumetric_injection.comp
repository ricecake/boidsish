        for (int y = -1; y <= 1; ++y) {
            for (int z = -1; z <= 1; ++z) {
                ivec3 cellPos = baseCell + ivec3(x, y, z);
                uint  h = uint(cellPos.x * 73856093) ^ uint(cellPos.y * 19349663) ^ uint(cellPos.z * 83492791);
                uint  cell_idx = h % u_grid_size;
                int   particle_idx = grid_heads[cell_idx];

                while (particle_idx != -1) {
                    Particle p = particles[particle_idx];
                    // Filter for emissive types
