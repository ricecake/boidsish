                        float radius = p.vel.w * 6.0; // Influence radius based on size
                        float radiusSq = radius * radius;

                        if (distSq < radiusSq) {
                            float atten = 1.0 - smoothstep(0.0, radiusSq, distSq);
                            // Fireflies are smaller but point-like, fires are larger and more intense
                            float intensityScale = (p.style == STYLE_FIREFLIES) ? 0.250 : 8.0;
