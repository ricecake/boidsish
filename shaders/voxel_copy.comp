#version 430 core
layout(local_size_x = 8, local_size_y = 8, local_size_z = 8) in;
layout(r32ui, binding = 0) uniform uimage3D u_src;
layout(r32f, binding = 1) uniform image3D u_dst;

void main() {
    ivec3 pos = ivec3(gl_GlobalInvocationID.xyz);
    uint val = imageLoad(u_src, pos).r;
    imageStore(u_dst, pos, vec4(float(val) / 1000.0, 0, 0, 0));
}
